{
  "version": 2,
  "builds": [
    {
      "src": "ATSI_website_mockup.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/public/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/public/videos/(.*)",
      "dest": "/public/videos/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/ATSI_website_mockup.html"
    }
  ],
  "headers": [
    {
      "source": "/public/videos/(.*\\.mp4)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/mp4"
        }
      ]
    },
    {
      "source": "/public/images/(.*\\.(jpeg|jpg|png))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
